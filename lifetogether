-- Sizes
local normalSize = UDim2.fromOffset(60, 60)
local hoverSize = UDim2.fromOffset(66, 66)
local clickSize = UDim2.fromOffset(54, 54)

local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

-- Hover
Button.MouseEnter:Connect(function()
	TweenService:Create(Button, tweenInfo, {Size = hoverSize}):Play()
end)

Button.MouseLeave:Connect(function()
	TweenService:Create(Button, tweenInfo, {Size = normalSize}):Play()
end)

-- Click
Button.Activated:Connect(function()
    	keyclick(0xA2)

	local shrink = TweenService:Create(Button, tweenInfo, {Size = clickSize})
	local expand = TweenService:Create(Button, tweenInfo, {Size = hoverSize})

	shrink:Play()
	shrink.Completed:Wait()
	expand:Play()

end)

-- Drag (PC + Mobile)
local dragging = false
local dragInput
local dragStart
local startPos

Button.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then

		dragging = true
		dragStart = input.Position
		startPos = Button.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

Button.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement
	or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input == dragInput then
		local delta = input.Position - dragStart

		Button.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)


