-- -------- NBA Quest --------
local NBAQuestActive = false
local function findMapFolder()
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Folder") and v.Name:lower():find("map") and v.Name:lower():find("props") then return v end
    end
    return nil
end
local function getCircle()
    local nba = Workspace:FindFirstChild("NBAIntegration")
    if not nba then return nil end
    local npc = nba:FindFirstChild("NPCArea")
    if not npc then return nil end
    return npc:FindFirstChild("Circle")
end
local function collectNBAProps()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then importantNotify("Error", "Character not ready", 3); return 0,0 end
    local folder = findMapFolder() or Workspace
    local models = {}
    for _, v in ipairs(folder:GetDescendants()) do
        if v:IsA("Model") and not v:FindFirstChild("owner") then table.insert(models, v) end
    end
    local total = #models
    if total == 0 then importantNotify("NBA Quest", "No props found", 3); return 0,0 end
    local collected = 0
    for _, model in ipairs(models) do
        if not NBAQuestActive then break end
        hrp.CFrame = model:GetPivot() + Vector3.new(0,3,0)
        collected += 1
        task.wait(0.2)
    end
    return collected, total
end
local function startNBAQuest()
    if NBAQuestActive then 
        importantNotify("NBA Quest", "Already running", 2)
        return 
    end
    
    NBAQuestActive = true
    importantNotify("NBA Quest", "Starting hunt...", 2)
    
    -- 1. Save current position (character and vehicle if seated)
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local originalCF = hrp and hrp.CFrame or nil
    local originalVehicle = getSeatedVehicle()  -- if you're in a vehicle, we'll restore later
    
    -- 2. Trigger NPC interaction
    pcall(Net.send, "nba_npc_interaction")
    task.wait(0.5)
    
    -- 3. Request to start the hunt
    pcall(Net.send, "nba_npc_request_start_hunt")
    task.wait(1)
    
    -- 4. Teleport to the circle
    local circle = getCircle()
    if circle and hrp then
        hrp.CFrame = circle.CFrame + Vector3.new(0, 3, 0)
        task.wait(0.6)
    end
    
    -- 5. Collect props
    local collected, total = collectNBAProps()
    
    -- 6. Teleport back to original position
    if originalCF and hrp and hrp.Parent then
        hrp.CFrame = originalCF
        -- If you were in a vehicle, re‑seat if possible (optional)
        if originalVehicle and originalVehicle.Parent then
            local seat = originalVehicle:FindFirstChildWhichIsA("VehicleSeat")
            if seat then
                hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
                task.wait(0.2)
                -- Simulate sitting? The game's own mechanics may handle it automatically.
            end
        end
        importantNotify("NBA Quest", "Returned to original location", 2)
    end
    
    NBAQuestActive = false
    
    if total > 0 then
        importantNotify("NBA Quest", string.format("Collected %d / %d props", collected, total), 4)
    else
        importantNotify("NBA Quest", "No props found", 3)
    end
end
