-- NBA Quest (unchanged, same as before)
local NBAQuestActive = false
local function findMapFolder()
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Folder") and v.Name:lower():find("map") and v.Name:lower():find("props") then return v end
    end
    return nil
end
local function getCircle()
    local nba = Workspace:FindFirstChild("NBAIntegration")
    if not nba then return nil end
    local npc = nba:FindFirstChild("NPCArea")
    if not npc then return nil end
    return npc:FindFirstChild("Circle")
end
local function collectNBAProps()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then notify("Character not ready"); return 0,0 end
    local folder = findMapFolder() or Workspace
    local models = {}
    for _, v in ipairs(folder:GetDescendants()) do
        if v:IsA("Model") and not v:FindFirstChild("owner") then table.insert(models, v) end
    end
    local total = #models
    if total == 0 then notify("No props found"); return 0,0 end
    local collected = 0
    for _, model in ipairs(models) do
        if not NBAQuestActive then break end
        hrp.CFrame = model:GetPivot() + Vector3.new(0,3,0)
        collected += 1
        task.wait(0.2)
    end
    return collected, total
end
local function startNBAQuest()
    if NBAQuestActive then notify("NBA Quest already running"); return end
    NBAQuestActive = true
    notify("Starting NBA Quest...")
    local circle = getCircle()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if circle and hrp then
        hrp.CFrame = circle.CFrame + Vector3.new(0,3,0)
        task.wait(0.6)
    end
    local collected, total = collectNBAProps()
    NBAQuestActive = false
    if total > 0 then
        notify(string.format("Collected %d / %d props", collected, total))
    else
        notify("No props found")
    end
end

-- FREEPAY (working)
local FreePayEnabled = false
local originals = {}
local Data = nil
local Modules = ReplicatedStorage:FindFirstChild("Modules")
if Modules then
    local Core = Modules:FindFirstChild("Core")
    if Core then
        local dataModule = Core:FindFirstChild("Data")
        if dataModule then
            local success, result = pcall(require, dataModule)
            if success then Data = result end
        end
    end
end

local function toggleFreePay()
    if not Data or not Data.initiate then
        notify("Data module not available", 4)
        return false
    end
    if not debug.getupvalue then
        notify("Executor does not support this feature", 4)
        return false
    end
    if not FreePayEnabled then
        notify("Enabling FreePay...", 2)
        local count = 0
        for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
            local attr = v:GetAttribute("IsVerifiedOnly")
            if attr ~= nil then
                originals[v] = attr
                v:SetAttribute("IsVerifiedOnly", false)
                count = count + 1
            end
        end
        pcall(function()
            local update = debug.getupvalue(Data.initiate, 2)
            if update then
                local _, original = Data.initiate("is_verified")
                originals["_is_verified"] = original
                update("is_verified", true)
            end
        end)
        FreePayEnabled = true
        notify(string.format("FreePay Activated! (%d features)", count), 4)
        return true
    else
        notify("Disabling FreePay...", 2)
        for obj, val in pairs(originals) do
            if obj ~= "_is_verified" and typeof(obj) == "Instance" and obj.Parent then
                if obj:GetAttribute("IsVerifiedOnly") ~= nil then
                    obj:SetAttribute("IsVerifiedOnly", val)
                end
            end
        end
        pcall(function()
            local update = debug.getupvalue(Data.initiate, 2)
            if update then
                update("is_verified", originals["_is_verified"] or false)
            end
        end)
        table.clear(originals)
        FreePayEnabled = false
        notify("FreePay Disabled", 4)
        return false
    end
end

