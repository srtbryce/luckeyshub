-- NET module loading
local function find_module_s(module_name)
    if not module_name then return nil end
    local base = ReplicatedStorage:FindFirstChild("Modules", true)
    if not base then return nil end
    local success, Modules = pcall(require, base)
    if not success then return nil end
    return Modules[module_name:lower()]
end

local Net = find_module_s("Net")
if not Net then error("Net module not found") end

local function Send(...) return pcall(Net.send, ...) end
local function Get(...) return pcall(Net.get, ...) end
