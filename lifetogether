-- -------- Car Cooker (silent toggle) --------
local CarCookerActive = false
local carCookerThread = nil

local function getCurrentVehicle()
    local char = lp.Character
    if not char then return nil end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid or not humanoid.SeatPart then return nil end
    local seat = humanoid.SeatPart
    if not seat or not seat.Parent then return nil end
    local vehicle = seat.Parent
    while vehicle and vehicle ~= workspace do
        if vehicle:IsA("Model") and (vehicle.PrimaryPart or vehicle:FindFirstChildWhichIsA("VehicleSeat") or vehicle:FindFirstChild("HumanoidRootPart")) then
            return vehicle
        end
        vehicle = vehicle.Parent
    end
    return nil
end

local function getVehicleRootPart(vehicle)
    if not vehicle then return nil end
    return vehicle:FindFirstChild("HumanoidRootPart") 
        or vehicle:FindFirstChild("Base") 
        or vehicle:FindFirstChildWhichIsA("BasePart")
        or vehicle.PrimaryPart
end

local function startCarCooker()
    if carCookerThread then return end
    carCookerThread = task.spawn(function()
        repeat
            RunService.Heartbeat:Wait()
            local vehicle = getCurrentVehicle()
            local root = vehicle and getVehicleRootPart(vehicle)
            while not (vehicle and root and root.Parent) do
                RunService.Heartbeat:Wait()
                vehicle = getCurrentVehicle()
                root = vehicle and getVehicleRootPart(vehicle)
            end
            local vel = root.Velocity
            local movel = 0.1
            root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
            RunService.RenderStepped:Wait()
            if CarCookerActive and vehicle and vehicle.Parent and root and root.Parent then root.Velocity = vel end
            RunService.Stepped:Wait()
            if CarCookerActive and vehicle and vehicle.Parent and root and root.Parent then
                root.Velocity = vel + Vector3.new(0, movel, 0)
                movel = movel * -1
            end
        until CarCookerActive == false
    end)
end

local function stopCarCooker()
    CarCookerActive = false
    if carCookerThread then task.cancel(carCookerThread); carCookerThread = nil end
    local vehicle = getCurrentVehicle()
    if vehicle then
        local root = getVehicleRootPart(vehicle)
        if root then root.Velocity = Vector3.zero; root.RotVelocity = Vector3.zero end
    end
end

local function toggleCarCooker()
    if not CarCookerActive then
        CarCookerActive = true
        startCarCooker()
    else
        stopCarCooker()
    end
end

