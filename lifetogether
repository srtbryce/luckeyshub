local function startFly(isVehicleFly)
    if Flying then stopFly() end
    Flying = true
    
    local targetPart = nil
    local vehicle = nil
    if isVehicleFly then
        vehicle = getSeatedVehicle()
        if vehicle then
            targetPart = vehicle:FindFirstChild("HumanoidRootPart") or vehicle:FindFirstChild("Base") or vehicle:FindFirstChildWhichIsA("BasePart")
        end
    end
    if not targetPart then
        targetPart = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not targetPart then
            importantNotify("Fly", "Character not ready", 2)
            stopFly()
            return
        end
    end
    
    local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
    if hum and not isVehicleFly then hum.PlatformStand = true end
    
    flyBV = Instance.new("BodyVelocity")
    flyBV.MaxForce = Vector3.new(9e9,9e9,9e9)
    flyBV.Velocity = Vector3.zero
    flyBV.Parent = targetPart
    
    flyBG = Instance.new("BodyGyro")
    flyBG.P = 9e4
    flyBG.MaxTorque = Vector3.new(9e9,9e9,9e9)
    flyBG.CFrame = targetPart.CFrame
    flyBG.Parent = targetPart
    
    local control = flyControl
    local cam = workspace.CurrentCamera
    
    flyConn = RunService.RenderStepped:Connect(function()
        if not Flying or not targetPart.Parent then
            stopFly()
            return
        end
        if isVehicleFly then
            local newVehicle = getSeatedVehicle()
            if newVehicle ~= vehicle then
                vehicle = newVehicle
                if vehicle then
                    targetPart = vehicle:FindFirstChild("HumanoidRootPart") or vehicle:FindFirstChild("Base") or vehicle:FindFirstChildWhichIsA("BasePart")
                    if targetPart then
                        flyBV.Parent = targetPart
                        flyBG.Parent = targetPart
                    else
                        stopFly()
                        return
                    end
                else
                    stopFly()
                    return
                end
            end
        end
        
        -- Read current speed every frame
        local currentSpeed = isVehicleFly and vehicleFlySpeed or flySpeed
        
        local moveVector = Vector3.zero
        local hasInput = false
        if control.F ~= 0 or control.B ~= 0 then
            moveVector = moveVector + cam.CFrame.LookVector * (control.F + control.B)
            hasInput = true
        end
        if control.L ~= 0 or control.R ~= 0 then
            moveVector = moveVector + cam.CFrame.RightVector * (control.L + control.R)
            hasInput = true
        end
        if QEfly and (control.Q ~= 0 or control.E ~= 0) then
            moveVector = moveVector + Vector3.new(0, (control.Q + control.E) * 0.2, 0)
            hasInput = true
        end
        
        if hasInput then
            flyBV.Velocity = moveVector.Unit * 50 * currentSpeed
        else
            flyBV.Velocity = Vector3.zero
        end
        
        flyBG.CFrame = cam.CFrame
        if isVehicleFly then cam.CameraType = Enum.CameraType.Track end
    end)
    
    -- 🔧 FIX: Use proper speed variables in key handlers
    flyKeyDown = UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        local key = input.KeyCode
        -- Get the current speed based on fly type
        local sp = isVehicleFly and vehicleFlySpeed or flySpeed
        if key == Enum.KeyCode.W then control.F = sp end
        if key == Enum.KeyCode.S then control.B = -sp end
        if key == Enum.KeyCode.A then control.L = -sp end
        if key == Enum.KeyCode.D then control.R = sp end
        if QEfly then
            if key == Enum.KeyCode.E then control.Q = sp * 2 end
            if key == Enum.KeyCode.Q then control.E = -sp * 2 end
        end
    end)
    
    flyKeyUp = UserInputService.InputEnded:Connect(function(input)
        local key = input.KeyCode
        if key == Enum.KeyCode.W then control.F = 0 end
        if key == Enum.KeyCode.S then control.B = 0 end
        if key == Enum.KeyCode.A then control.L = 0 end
        if key == Enum.KeyCode.D then control.R = 0 end
        if key == Enum.KeyCode.E then control.Q = 0 end
        if key == Enum.KeyCode.Q then control.E = 0 end
    end)
end

-- Mobile fly (fixed similarly)
local mobileFlyActive = false
local mobileFlyConn = nil
local mobileFlyBV = nil
local mobileFlyBG = nil

local function stopMobileFly()
    mobileFlyActive = false
    if mobileFlyConn then mobileFlyConn:Disconnect(); mobileFlyConn = nil end
    if mobileFlyBV then mobileFlyBV:Destroy(); mobileFlyBV = nil end
    if mobileFlyBG then mobileFlyBG:Destroy(); mobileFlyBG = nil end
    local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = false end
end

local function startMobileFly(isVehicleFly)
    if mobileFlyActive then stopMobileFly() end
    mobileFlyActive = true
    
    local targetPart = nil
    local vehicle = nil
    if isVehicleFly then
        vehicle = getSeatedVehicle()
        if vehicle then
            targetPart = vehicle:FindFirstChild("HumanoidRootPart") or vehicle:FindFirstChild("Base") or vehicle:FindFirstChildWhichIsA("BasePart")
        end
    end
    if not targetPart then
        targetPart = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not targetPart then
            importantNotify("Fly", "Character not ready", 2)
            stopMobileFly()
            return
        end
    end
    
    local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
    if hum and not isVehicleFly then hum.PlatformStand = true end
    
    mobileFlyBV = Instance.new("BodyVelocity")
    mobileFlyBV.MaxForce = Vector3.new(9e9,9e9,9e9)
    mobileFlyBV.Velocity = Vector3.zero
    mobileFlyBV.Parent = targetPart
    
    mobileFlyBG = Instance.new("BodyGyro")
    mobileFlyBG.P = 9e4
    mobileFlyBG.MaxTorque = Vector3.new(9e9,9e9,9e9)
    mobileFlyBG.CFrame = targetPart.CFrame
    mobileFlyBG.Parent = targetPart
    
    local controlModule = require(lp.PlayerScripts:WaitForChild("PlayerModule"):WaitForChild("ControlModule"))
    local cam = workspace.CurrentCamera
    
    mobileFlyConn = RunService.RenderStepped:Connect(function()
        if not mobileFlyActive or not targetPart.Parent then
            stopMobileFly()
            return
        end
        local move = controlModule:GetMoveVector()
        local currentSpeed = isVehicleFly and vehicleFlySpeed or flySpeed
        if move.Magnitude > 0 then
            mobileFlyBV.Velocity = (cam.CFrame.LookVector * -move.Z + cam.CFrame.RightVector * move.X) * 50 * currentSpeed
        else
            mobileFlyBV.Velocity = Vector3.zero
        end
        mobileFlyBG.CFrame = cam.CFrame
        if isVehicleFly then cam.CameraType = Enum.CameraType.Track end
    end)
end

local FlyActive = false
local VehicleFlyActive = false

local function toggleFly()
    if UserInputService.TouchEnabled then
        if not FlyActive then startMobileFly(false); FlyActive = true else stopMobileFly(); FlyActive = false end
    else
        if not FlyActive then startFly(false); FlyActive = true else stopFly(); FlyActive = false end
    end
end

local function toggleVehicleFly()
    if UserInputService.TouchEnabled then
        if not VehicleFlyActive then startMobileFly(true); VehicleFlyActive = true else stopMobileFly(); VehicleFlyActive = false end
    else
        if not VehicleFlyActive then startFly(true); VehicleFlyActive = true else stopFly(); VehicleFlyActive = false end
    end
end

