-- Click selection button (improved raycast version, no extra GUI)
local selectingTarget = false
local selectionConnection = nil
local chatConn = nil

local function stopTargetSelection()
    if selectionConnection then
        selectionConnection:Disconnect()
        selectionConnection = nil
    end
    if chatConn then
        chatConn:Disconnect()
        chatConn = nil
    end
    selectingTarget = false
end

local function startTargetSelection()
    if selectingTarget then
        importantNotify("Copy Avatar", "Already selecting a target", 2)
        return
    end
    selectingTarget = true
    importantNotify("Copy Avatar", "Click/Tap on any player to copy their avatar (type 'cancel' in chat to stop)", 5)
    
    -- Cancel via chat
    chatConn = game:GetService("TextChatService").MessageReceived:Connect(function(msg)
        if msg.TextSource == lp and msg.Text:lower() == "cancel" then
            stopTargetSelection()
            importantNotify("Copy Avatar", "Target selection cancelled", 2)
        end
    end)
    
    -- Raycast picker (works on PC, mobile, console)
    selectionConnection = game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local screenPos = input.Position
            if not screenPos and input.UserInputType == Enum.UserInputType.Touch then
                local touches = game:GetService("UserInputService"):GetTouchPositions()
                if #touches > 0 then screenPos = touches[1] end
            end
            if not screenPos then return end
            
            local camera = workspace.CurrentCamera
            local ray = camera:ScreenPointToRay(screenPos.X, screenPos.Y)
            local params = RaycastParams.new()
            params.FilterType = Enum.RaycastFilterType.Blacklist
            params.FilterDescendantsInstances = {lp.Character}
            local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
            
            if result then
                local model = result.Instance:FindFirstAncestorWhichIsA("Model")
                if model and model:FindFirstChildOfClass("Humanoid") then
                    local targetPlayer = Players:GetPlayerFromCharacter(model)
                    if targetPlayer and targetPlayer ~= lp then
                        stopTargetSelection()
                        copyPlayerAvatar(targetPlayer)
                        return
                    end
                end
            end
            -- Missed click feedback (brief notification)
            importantNotify("Copy Avatar", "Click directly on a player's body", 1)
        end
    end)
end

