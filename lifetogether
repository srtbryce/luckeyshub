-- -------- Rainbow Vehicle (auto-disable notification important) --------
local RainbowVehActive = false
local rainbowVehThread = nil

local function changeVehicleColor(color, vehicle)
    if not vehicle then return end
    local part = vehicle:FindFirstChild("BodyColors") 
        or vehicle:FindFirstChild("ColorPart") 
        or vehicle:FindFirstChild("VehicleSeat")
    if part then part.Color = color end
    if Send then Send("vehicle_color", color, vehicle) end
end

local function toggleRainbowVehicle()
    RainbowVehActive = not RainbowVehActive

    if RainbowVehActive then
        rainbowVehThread = task.spawn(function()
            local hue = 0
            local vehicle = getOwnedVehicle()
            local noVehicleTimer = 0
            local lastCheck = tick()

            while RainbowVehActive do
                local now = tick()
                if not vehicle or not vehicle.Parent then
                    if now - lastCheck >= 1 then
                        vehicle = getOwnedVehicle()
                        lastCheck = now
                        if not vehicle then
                            noVehicleTimer = noVehicleTimer + 1
                            if noVehicleTimer >= 3 then
                                importantNotify("Rainbow Vehicle", "No owned vehicle found, auto-disabled", 4)
                                toggleRainbowVehicle()
                                return
                            end
                        else
                            noVehicleTimer = 0
                        end
                    end
                else
                    noVehicleTimer = 0
                end

                if vehicle then
                    local color = Color3.fromHSV(hue, 1, 1)
                    changeVehicleColor(color, vehicle)
                end

                hue = (hue + 0.016) % 1
                task.wait(0.03)
            end
        end)
    else
        if rainbowVehThread then task.cancel(rainbowVehThread); rainbowVehThread = nil end
    end
end

